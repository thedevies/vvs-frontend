{
  "expo": {
    "name": "VVS",
    "slug": "vvs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "vvs",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo.png",
      "bundleIdentifier": "com.vvs.matrimony"
    },
    "android": {
      "icon": "./assets/images/logo.png",
      "package": "com.vvs.matrimony",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#FF4D8D"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 200,
            "resizeMode": "contain"
          },
          "ios": {
            "image": "./assets/images/logo.png",
            "imageWidth": 200,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50be3265-a42d-4cb9-9032-4a0d56c6fc7c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
